# SQLite database file name (will be created as <DB_NAME>.db)
DB_NAME=xya_panel

# Redis (for Celery broker)
REDIS_URL=redis://localhost:6379/0

# Master secret for HKDF key derivation (generate with: python -c "import secrets; print(secrets.token_hex(32))")
MASTER_SECRET=change-me-to-a-64-char-hex-string

# JWT signing secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-another-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Admin account bootstrap
ADMIN_EMAIL=admin@xya.local
ADMIN_PASSWORD_HASH=  # bcrypt hash of initial password; generate with: python3 << 'EOF'
                       # import bcrypt
                       # print(bcrypt.hashpw(b'password', bcrypt.gensalt()).decode())
                       # EOF

# Server host/port
HOST=0.0.0.0
PORT=8000
